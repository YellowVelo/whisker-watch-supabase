# Copy this file to .env for local development. .env is gitignored —
# never commit real values.
#
# Get these from your Supabase project: Settings -> API.
#
# Which project to point at:
#   Local dev            -> wysker-watch-dev
#   staging branch/deploy -> wysker-watch-staging (set in the Cloudflare
#                            Pages dashboard, not in a committed file)
#   main / production     -> wysker-watch (prod) (set wherever prod's
#                            build environment is configured)
#
# Never point your local .env at the production project — a local dev
# server writes real data through it.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
